# Even Lab Dashboard — environment template. Copy to .env.local and fill in.
# NEVER commit the real .env / key files.

# --- Database (GCP Cloud SQL for PostgreSQL, asia-south1 / Mumbai) ---
# For local dev or public-IP+SSL connections:
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/evenlab?sslmode=require
# For Cloud SQL connector (recommended in prod): set the instance + use IAM auth
CLOUD_SQL_INSTANCE=PROJECT:asia-south1:evenlab-pg
DB_USER=evenlab_app
DB_NAME=evenlab

# --- Google Cloud Storage (asia-south1 / Mumbai) ---
GCS_BUCKET=evenlab-files-asia-south1

# --- Vertex AI (Gemini) ---
GCP_PROJECT_ID=your-project-id
VERTEX_LOCATION=asia-south1
VERTEX_MODEL=gemini-best-available   # confirm exact enabled model in console

# --- GCP credentials ---
# Path to the service-account key (DO NOT commit). In Vercel, store the JSON
# contents in an env var / secret instead of a file on disk.
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-service-account.json

# --- Auth (single Lab Director account) ---
AUTH_EMAIL=labdirector@even.in
AUTH_PASSWORD_HASH=   # argon2/bcrypt hash, set during setup
SESSION_SECRET=       # random 32+ byte string

# --- Reminders (later phase, WaSender) ---
WASENDER_ENABLED=false
