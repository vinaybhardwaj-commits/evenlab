# Even Lab Dashboard — environment template. Copy to .env.local and fill in.
# NEVER commit the real .env / key files.

# --- Database + file storage: Neon Postgres (everything lives here) ---
# Use Neon's POOLED connection string (the "-pooler" host) with sslmode=require.
DATABASE_URL=postgres://USER:PASSWORD@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/evenlab?sslmode=require

# --- Auth (single Lab Director account) ---
AUTH_EMAIL=chandrakala.ln@even.in
AUTH_PASSWORD_HASH=   # bcrypt hash — generate with: node -e "console.log(require('bcryptjs').hashSync(process.argv[1],12))" 'your-password'
SESSION_SECRET=       # random 32+ char string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# --- Vertex AI (Gemini only; org GCP is used for Gemini, not storage) ---
# Only de-identified aggregates are sent — region need not be India.
GCP_PROJECT_ID=clinical-infra
VERTEX_LOCATION=global            # or us-central1 (Gemini 2.5 Pro isn't in asia-south1)
VERTEX_MODEL=gemini-2.5-pro       # confirm the enabled model in the console
# Paste the Vertex service-account JSON contents here (Vercel env var / secret, NOT a committed file)
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# --- Reminders (later phase, WaSender) ---
WASENDER_ENABLED=false
